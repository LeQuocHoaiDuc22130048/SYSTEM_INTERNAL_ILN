# Environment Variables Template
# Copy this file to .env and update with your actual values

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=system_internal_inl
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=your_redis_password  # Optional: if Redis requires auth

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_min_32_characters_long
JWT_EXPIRATION_MS=604800000

# Initial Users
BOSS_USER=boss
BOSS_PASS=your_boss_password
BOSS_FULL_NAME="Đỗ Xuân Vỹ"

ADMIN_USER=admin
ADMIN_PASS=your_admin_password
ADMIN_FULL_NAME="Admin System"

# Server Configuration
SERVER_PORT=8888

# CORS Configuration (Production)
CORS_ALLOWED_ORIGINS=https://your-mobile-app.com,https://your-web-app.com